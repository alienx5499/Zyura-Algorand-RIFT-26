{
  "name": "contracts",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "watcher": "npx ts-node scripts/watcher.ts",
    "payout": "npx ts-node scripts/run-payout.ts",
    "generate-client": "algokit generate client artifacts/ --language typescript  --output clients/{contract_name}Client.ts",
    "compile-contract": "tealscript *.algo.ts artifacts",
    "generate-components": "algokit-generate-component artifacts/Zyura.arc32.json artifacts/components",
    "build": "npm run compile-contract && npm run generate-client",
    "test": "npm run build && jest",
    "test:only": "jest",
    "lint": "eslint . --ext .ts",
    "fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^7.0.0",
    "algosdk": ">=2.9.0 <3.0",
    "dotenv": "^17.3.1",
    "bip39": "^3.1.0",
    "ed25519-hd-key": "^1.3.0"
  },
  "devDependencies": {
    "@algorandfoundation/algokit-client-generator": "^4.0.0",
    "@algorandfoundation/tealscript": "latest",
    "@jest/globals": "^29.5.0",
    "@joe-p/algokit-generate-component": "^0.2.0",
    "@typescript-eslint/eslint-plugin": "^5.13.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^7.32.0 || ^8.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.5.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.0",
    "typescript": "5.0.2"
  }
}
